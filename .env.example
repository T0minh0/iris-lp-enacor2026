# Conexão com o Postgres próprio.
# No Coolify, use o HOST INTERNO do serviço de banco (rede do projeto),
# algo como: postgres://usuario:senha@iris-db:5432/iris
DATABASE_URL=postgres://usuario:senha@localhost:5432/iris

# SSL do Postgres:
#   "true"  → bancos gerenciados que exigem TLS
#   "false" → Postgres interno do Coolify (mesma rede) — padrão
PGSSL=false
